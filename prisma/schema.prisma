generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  // Owned items
  tasks      Task[]
  categories Category[]

  // Activity
  taskUpdates TaskUpdate[]
  timeLogs    TimeLog[]

  // Workout module
  exercises          Exercise[]         @relation("UserExercises")
  exerciseCategories ExerciseCategory[] @relation("UserExerciseCategories")
  bodyAreas          BodyArea[]         @relation("UserBodyAreas")
  workoutPlans       WorkoutPlan[]      @relation("UserWorkoutPlans")

  // DebtFlow module
  debtCards          DebtCard[]         @relation("UserDebtCards")

  @@map("users")
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?  @map("due_date")
  isShared    Boolean    @default(false) @map("is_shared")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  categories  TaskCategory[]
  updates     TaskUpdate[]
  timeLogs    TimeLog[]

  @@map("tasks")
}


model Category {
  id          String  @id @default(cuid())
  name        String
  description String?
  color       String  @default("#f59e0b")
  isShared    Boolean @default(false) @map("is_shared")
  createdAt   DateTime @default(now()) @map("created_at")

  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  parentId String?    @map("parent_id")
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  tasks TaskCategory[]

  @@map("categories")
}

// Many-to-many: Task <-> Category
model TaskCategory {
  taskId     String @map("task_id")
  categoryId String @map("category_id")

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([taskId, categoryId])
  @@map("task_categories")
}

// Append-only notes log per task
model TaskUpdate {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  taskId String @map("task_id")
  userId String @map("user_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_updates")
}

// Time logging per task
model TimeLog {
  id              String   @id @default(cuid())
  durationMinutes Int      @map("duration_minutes")
  description     String?
  loggedAt        DateTime @default(now()) @map("logged_at")

  taskId String @map("task_id")
  userId String @map("user_id")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("time_logs")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// ── Workout module ────────────────────────────────────────────────────────────

enum DayType {
  UPPER
  LOWER
  FULL_BODY
  CARDIO
  REST
}

model ExerciseCategory {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  ownerId String @map("owner_id")
  owner   User   @relation("UserExerciseCategories", fields: [ownerId], references: [id], onDelete: Cascade)

  exercises ExerciseCategoryLink[]

  @@map("exercise_categories")
}

model BodyArea {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  ownerId String @map("owner_id")
  owner   User   @relation("UserBodyAreas", fields: [ownerId], references: [id], onDelete: Cascade)

  exercises ExerciseBodyAreaLink[]

  @@map("body_areas")
}

model Exercise {
  id        String   @id @default(cuid())
  name      String
  videoUrl  String?  @map("video_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ownerId String @map("owner_id")
  owner   User   @relation("UserExercises", fields: [ownerId], references: [id], onDelete: Cascade)

  categories          ExerciseCategoryLink[]
  bodyAreas           ExerciseBodyAreaLink[]
  workoutDayExercises WorkoutDayExercise[]

  @@map("exercises")
}

// Many-to-many: Exercise <-> ExerciseCategory
model ExerciseCategoryLink {
  exerciseId String @map("exercise_id")
  categoryId String @map("category_id")

  exercise Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  category ExerciseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([exerciseId, categoryId])
  @@map("exercise_category_links")
}

// Many-to-many: Exercise <-> BodyArea
model ExerciseBodyAreaLink {
  exerciseId String @map("exercise_id")
  bodyAreaId String @map("body_area_id")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  bodyArea BodyArea @relation(fields: [bodyAreaId], references: [id], onDelete: Cascade)

  @@id([exerciseId, bodyAreaId])
  @@map("exercise_body_area_links")
}

model WorkoutPlan {
  id          String   @id @default(cuid())
  name        String
  daysPerWeek Int      @map("days_per_week")
  isActive    Boolean  @default(false) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  ownerId String @map("owner_id")
  owner   User   @relation("UserWorkoutPlans", fields: [ownerId], references: [id], onDelete: Cascade)

  days WorkoutDay[]

  @@map("workout_plans")
}

model WorkoutDay {
  id        String  @id @default(cuid())
  dayNumber Int     @map("day_number")
  label     String?
  dayType   DayType @map("day_type")

  planId String      @map("plan_id")
  plan   WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  exercises WorkoutDayExercise[]

  @@map("workout_days")
}

model WorkoutDayExercise {
  id        String @id @default(cuid())
  sortOrder Int    @map("sort_order")

  targetSets   Int?   @map("target_sets")
  targetReps   Int?   @map("target_reps")
  targetWeight Float? @map("target_weight")

  lastSets        Int?      @map("last_sets")
  lastReps        Int?      @map("last_reps")
  lastWeight      Float?    @map("last_weight")
  lastPerformedAt DateTime? @map("last_performed_at")

  dayId      String @map("day_id")
  exerciseId String @map("exercise_id")

  day      WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("workout_day_exercises")
}

// ── DebtFlow module ────────────────────────────────────────────────────────────

model DebtCard {
  id             String   @id @default(cuid())
  name           String
  totalDebt      Float    @map("total_debt")
  apr            Float
  monthlyPayment Float    @map("monthly_payment")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  ownerId String @map("owner_id")
  owner   User   @relation("UserDebtCards", fields: [ownerId], references: [id], onDelete: Cascade)

  balanceTransfers BalanceTransfer[]

  @@map("debt_cards")
}

model BalanceTransfer {
  id              String   @id @default(cuid())
  amount          Float
  expiresInMonths Int      @map("expires_in_months")
  createdAt       DateTime @default(now()) @map("created_at")

  cardId String @map("card_id")
  card   DebtCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("balance_transfers")
}
